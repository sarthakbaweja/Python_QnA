GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_USE_TLS=false
QDRANT_COLLECTION=python_qna
ACTIVE_PROMPT_VERSION=v1
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://localhost:8501

# Local dev (not Docker): set QDRANT_HOST=localhost, BACKEND_URL=http://localhost:8000
# Qdrant Cloud (prod):    set QDRANT_HOST=<cluster>.qdrant.io, QDRANT_API_KEY=<key>, QDRANT_USE_TLS=true
